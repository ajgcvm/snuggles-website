---
import Layout from '../layouts/Layout.astro'
import { Image } from 'astro:assets'
import heroImage from '../assets/images/doc_rolling.jpg'
import dogWater from '../assets/images/profile_pic.jpg'
---

<Layout title="Snuggles Pet Boarding | Melbourne, FL">
  <!-- Header -->
  <header class="fixed top-0 left-0 right-0 z-50 bg-white/90 backdrop-blur-sm border-b border-stone-200">
    <nav class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">
      <a href="/" class="text-xl font-bold text-primary-700">
        Snuggles Pet Boarding
      </a>
      <div class="hidden md:flex items-center gap-8">
        <a href="#services" class="text-stone-600 hover:text-primary-700 transition-colors">Services</a>
        <a href="#why-us" class="text-stone-600 hover:text-primary-700 transition-colors">Why Us</a>
        <a href="#gallery" class="text-stone-600 hover:text-primary-700 transition-colors">Gallery</a>
        <a href="#about" class="text-stone-600 hover:text-primary-700 transition-colors">About</a>
        <a href="#contact" class="bg-primary-600 text-white px-5 py-2 rounded-full hover:bg-primary-700 transition-colors font-medium">
          Book Now
        </a>
      </div>
      <!-- Mobile menu button -->
      <button id="mobile-menu-btn" class="md:hidden p-2">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </nav>
    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden md:hidden bg-white border-t border-stone-200">
      <div class="px-4 py-4 space-y-4">
        <a href="#services" class="block text-stone-600 hover:text-primary-700">Services</a>
        <a href="#why-us" class="block text-stone-600 hover:text-primary-700">Why Us</a>
        <a href="#gallery" class="block text-stone-600 hover:text-primary-700">Gallery</a>
        <a href="#about" class="block text-stone-600 hover:text-primary-700">About</a>
        <a href="#contact" class="block bg-primary-600 text-white px-5 py-2 rounded-full text-center font-medium">Book Now</a>
      </div>
    </div>
  </header>

  <main>
    <!-- Hero Section -->
    <section class="relative min-h-screen flex items-center justify-center overflow-hidden">
      <Image
        src={heroImage}
        alt="Happy dog rolling in grass at Snuggles Pet Boarding farm"
        class="absolute inset-0 w-full h-full object-cover"
        widths={[640, 1024, 1920]}
        sizes="100vw"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-black/40 via-black/30 to-black/50"></div>
      <div class="relative z-10 text-center px-4 max-w-4xl mx-auto">
        <h1 class="font-serif text-4xl md:text-6xl lg:text-7xl font-bold text-white mb-6 drop-shadow-lg">
          Where Pets Roam Free
        </h1>
        <p class="text-xl md:text-2xl text-white/90 mb-8 max-w-2xl mx-auto drop-shadow">
          Not a kennel. A farm vacation for your furry family.
          Dogs, cats, and birds welcome.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="#contact" class="bg-primary-500 hover:bg-primary-600 text-white px-8 py-4 rounded-full text-lg font-semibold transition-all hover:scale-105 shadow-lg">
            Schedule a Meet & Greet
          </a>
          <a href="#services" class="bg-white/20 hover:bg-white/30 backdrop-blur text-white px-8 py-4 rounded-full text-lg font-semibold transition-all border border-white/30">
            View Services
          </a>
        </div>
      </div>
      <!-- Scroll indicator -->
      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
        <svg class="w-8 h-8 text-white/70" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
        </svg>
      </div>
    </section>

    <!-- Services Section -->
    <section id="services" class="py-20 md:py-28 bg-white">
      <div class="max-w-6xl mx-auto px-4">
        <div class="text-center mb-16">
          <h2 class="font-serif text-3xl md:text-4xl font-bold text-stone-800 mb-4">Our Services</h2>
          <p class="text-lg text-stone-600 max-w-2xl mx-auto">
            Whether you're traveling for a week or just need a day of fun for your pet, we've got you covered.
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-6">
          <!-- Dogs -->
          <div class="bg-stone-50 rounded-2xl p-6 border border-stone-200 hover:border-primary-300 transition-colors">
            <div class="w-12 h-12 bg-primary-100 rounded-xl flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.121 14.121L19 19m-7-7l7-7m-7 7l-2.879 2.879M12 12L9.121 9.121m0 5.758a3 3 0 10-4.243 4.243 3 3 0 004.243-4.243zm0 0L9.121 9.121"/>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-stone-800 mb-4">Dogs</h3>

            <div class="space-y-4">
              <div>
                <div class="flex items-baseline justify-between mb-1">
                  <span class="text-stone-600">Boarding</span>
                  <span class="font-bold text-primary-700">$40-50<span class="text-sm font-normal text-stone-500">/night</span></span>
                </div>
              </div>
              <div>
                <div class="flex items-baseline justify-between mb-1">
                  <span class="text-stone-600">Daycare</span>
                  <span class="font-bold text-primary-700">$30-35<span class="text-sm font-normal text-stone-500">/day</span></span>
                </div>
              </div>
            </div>

            <div class="mt-4 pt-4 border-t border-stone-200">
              <ul class="space-y-1 text-sm text-stone-500">
                <li class="flex items-center gap-2">
                  <svg class="w-4 h-4 text-primary-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                  </svg>
                  Daily photo updates
                </li>
                <li class="flex items-center gap-2">
                  <svg class="w-4 h-4 text-primary-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                  </svg>
                  Outdoor farm experience
                </li>
              </ul>
            </div>
          </div>

          <!-- Cats -->
          <div class="bg-stone-50 rounded-2xl p-6 border border-stone-200 hover:border-primary-300 transition-colors">
            <div class="w-12 h-12 bg-primary-100 rounded-xl flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-stone-800 mb-4">Cats</h3>

            <div class="space-y-4">
              <div>
                <div class="flex items-baseline justify-between mb-1">
                  <span class="text-stone-600">Boarding</span>
                  <span class="font-bold text-primary-700">$30-35<span class="text-sm font-normal text-stone-500">/night</span></span>
                </div>
              </div>
            </div>

            <div class="mt-4 pt-4 border-t border-stone-200">
              <ul class="space-y-1 text-sm text-stone-500">
                <li class="flex items-center gap-2">
                  <svg class="w-4 h-4 text-primary-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                  </svg>
                  Quiet, safe environment
                </li>
                <li class="flex items-center gap-2">
                  <svg class="w-4 h-4 text-primary-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                  </svg>
                  Daily updates
                </li>
              </ul>
            </div>
          </div>

          <!-- Other Pets -->
          <div class="bg-stone-50 rounded-2xl p-6 border border-stone-200 hover:border-primary-300 transition-colors">
            <div class="w-12 h-12 bg-primary-100 rounded-xl flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-stone-800 mb-4">Other Pets</h3>

            <div class="space-y-4">
              <div>
                <div class="flex items-baseline justify-between mb-1">
                  <span class="text-stone-600">All services</span>
                  <span class="font-bold text-primary-700">$25<span class="text-sm font-normal text-stone-500">/day</span></span>
                </div>
              </div>
            </div>

            <div class="mt-4 pt-4 border-t border-stone-200">
              <ul class="space-y-1 text-sm text-stone-500">
                <li class="flex items-center gap-2">
                  <svg class="w-4 h-4 text-primary-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                  </svg>
                  Birds, chinchillas, fish
                </li>
                <li class="flex items-center gap-2">
                  <svg class="w-4 h-4 text-primary-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                  </svg>
                  Specialized care
                </li>
              </ul>
            </div>
          </div>
        </div>

        <div class="mt-10 p-4 bg-stone-100 rounded-xl text-center">
          <p class="text-sm text-stone-600">
            <span class="font-medium">Rates vary</span> for puppies, pets on medication, and holidays/high demand periods.
            <br class="hidden sm:block" />
            <a href="#contact" class="text-primary-600 hover:text-primary-700 font-medium">Contact us</a> for a personalized quote.
          </p>
        </div>
      </div>
    </section>

    <!-- Why Us Section -->
    <section id="why-us" class="py-20 md:py-28 bg-primary-50">
      <div class="max-w-6xl mx-auto px-4">
        <div class="text-center mb-16">
          <h2 class="font-serif text-3xl md:text-4xl font-bold text-stone-800 mb-4">Why Snuggles?</h2>
          <p class="text-lg text-stone-600 max-w-2xl mx-auto">
            We're not your typical boarding facility. Here's what makes us different.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
          <!-- Farm Environment -->
          <div class="bg-white rounded-xl p-6 text-center shadow-sm">
            <div class="w-16 h-16 bg-primary-100 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/>
              </svg>
            </div>
            <h3 class="font-bold text-lg text-stone-800 mb-2">Farm Experience</h3>
            <p class="text-stone-600 text-sm">
              Open fields, fresh air, and room to run. No cages, no kennels - just nature.
            </p>
          </div>

          <!-- All Pets Welcome -->
          <div class="bg-white rounded-xl p-6 text-center shadow-sm">
            <div class="w-16 h-16 bg-primary-100 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
              </svg>
            </div>
            <h3 class="font-bold text-lg text-stone-800 mb-2">All Pets Welcome</h3>
            <p class="text-stone-600 text-sm">
              Dogs, cats, birds, and more. Bring the whole family - we'll take care of everyone.
            </p>
          </div>

          <!-- Daily Updates -->
          <div class="bg-white rounded-xl p-6 text-center shadow-sm">
            <div class="w-16 h-16 bg-primary-100 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </div>
            <h3 class="font-bold text-lg text-stone-800 mb-2">Daily Updates</h3>
            <p class="text-stone-600 text-sm">
              Photos and updates every day. You'll never wonder how your pet is doing.
            </p>
          </div>

          <!-- Family Owned -->
          <div class="bg-white rounded-xl p-6 text-center shadow-sm">
            <div class="w-16 h-16 bg-primary-100 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
              </svg>
            </div>
            <h3 class="font-bold text-lg text-stone-800 mb-2">Family Owned</h3>
            <p class="text-stone-600 text-sm">
              Personal attention from people who truly love animals. Your pet becomes part of our family.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Gallery Section -->
    <section id="gallery" class="py-20 md:py-28 bg-white">
      <div class="max-w-6xl mx-auto px-4">
        <div class="text-center mb-16">
          <h2 class="font-serif text-3xl md:text-4xl font-bold text-stone-800 mb-4">Happy Guests</h2>
          <p class="text-lg text-stone-600 max-w-2xl mx-auto">
            See what a day at Snuggles looks like.
          </p>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
          <div class="aspect-square overflow-hidden rounded-xl">
            <Image
              src={heroImage}
              alt="Dog enjoying the farm"
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
              widths={[400, 600]}
              sizes="(max-width: 768px) 50vw, 33vw"
            />
          </div>
          <div class="aspect-square overflow-hidden rounded-xl">
            <Image
              src={dogWater}
              alt="Dog playing in water"
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
              widths={[400, 600]}
              sizes="(max-width: 768px) 50vw, 33vw"
            />
          </div>
          <!-- Placeholder for more photos -->
          <div class="aspect-square overflow-hidden rounded-xl bg-stone-100 flex items-center justify-center">
            <div class="text-center text-stone-400 p-4">
              <svg class="w-12 h-12 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
              </svg>
              <span class="text-sm">More photos coming soon</span>
            </div>
          </div>
        </div>

        <div class="text-center mt-8">
          <a href="https://instagram.com/snugglespetboarding" target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-primary-600 hover:text-primary-700 font-medium">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
            Follow us on Instagram
          </a>
        </div>
      </div>
    </section>

    <!-- About Section -->
    <section id="about" class="py-20 md:py-28 bg-stone-100">
      <div class="max-w-6xl mx-auto px-4">
        <div class="grid md:grid-cols-2 gap-12 items-center">
          <div>
            <h2 class="font-serif text-3xl md:text-4xl font-bold text-stone-800 mb-6">About Snuggles</h2>
            <div class="space-y-4 text-stone-600">
              <p>
                Located on a beautiful farm in Melbourne, Florida, Snuggles Pet Boarding
                was born from a simple belief: pets deserve better than traditional kennels.
              </p>
              <p>
                Here, your furry (or feathered!) family members get to experience life on a real farm.
                They'll explore open fields, make new friends, and enjoy the kind of freedom
                that only nature can provide.
              </p>
              <p>
                We're not just pet sitters - we're animal lovers who treat every guest
                like part of our own family. From daily photo updates to personalized care,
                we go above and beyond to make sure your pet has the time of their life.
              </p>
            </div>
          </div>
          <div class="relative">
            <div class="aspect-[4/3] rounded-2xl overflow-hidden">
              <Image
                src={dogWater}
                alt="Happy dog at Snuggles"
                class="w-full h-full object-cover"
                widths={[400, 600, 800]}
                sizes="(max-width: 768px) 100vw, 50vw"
              />
            </div>
            <div class="absolute -bottom-6 -left-6 bg-primary-500 text-white px-6 py-4 rounded-xl shadow-lg">
              <div class="text-3xl font-bold">5+</div>
              <div class="text-sm">Years of Experience</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Contact Section -->
    <section id="contact" class="py-20 md:py-28 bg-white">
      <div class="max-w-6xl mx-auto px-4">
        <div class="text-center mb-16">
          <h2 class="font-serif text-3xl md:text-4xl font-bold text-stone-800 mb-4">Get In Touch</h2>
          <p class="text-lg text-stone-600 max-w-2xl mx-auto">
            Ready to give your pet the farm vacation they deserve?
            Schedule a meet & greet or send us a message.
          </p>
        </div>

        <div class="grid md:grid-cols-2 gap-12">
          <!-- Contact Info -->
          <div class="space-y-8">
            <div>
              <h3 class="font-bold text-lg text-stone-800 mb-4">Contact Information</h3>
              <div class="space-y-4">
                <a href="tel:+19549077750" class="flex items-center gap-3 text-stone-600 hover:text-primary-600 transition-colors">
                  <div class="w-10 h-10 bg-primary-100 rounded-full flex items-center justify-center">
                    <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                    </svg>
                  </div>
                  <span>(954) 907-7750</span>
                </a>
                <a href="https://maps.google.com/?q=4253+Pinewood+Rd+Melbourne+FL" target="_blank" rel="noopener" class="flex items-start gap-3 text-stone-600 hover:text-primary-600 transition-colors">
                  <div class="w-10 h-10 bg-primary-100 rounded-full flex items-center justify-center flex-shrink-0">
                    <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
