---
import Layout from '../layouts/Layout.astro'
import logoIcon from '../assets/images/logo-expanded.svg'

const API_URL = 'https://denboard-booking-api.felhen.workers.dev'
---

<Layout title="Admin | Snuggles Pet Boarding">
  <!-- Login Modal -->
  <div id="login-modal" class="fixed inset-0 bg-black/50 flex items-center justify-center z-50">
    <div class="bg-white rounded-2xl p-8 max-w-sm w-full mx-4 shadow-xl">
      <div class="text-center mb-6">
        <img src={logoIcon.src} alt="Snuggles" class="w-16 h-16 mx-auto mb-4" />
        <h1 class="text-xl font-bold text-stone-800">Admin Login</h1>
      </div>
      <form id="login-form" class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-stone-700 mb-1">Username</label>
          <input type="text" id="username" value="admin" class="w-full px-4 py-2 border border-stone-300 rounded-lg focus:ring-2 focus:ring-primary-500" />
        </div>
        <div>
          <label class="block text-sm font-medium text-stone-700 mb-1">Password</label>
          <input type="password" id="password" class="w-full px-4 py-2 border border-stone-300 rounded-lg focus:ring-2 focus:ring-primary-500" />
        </div>
        <button type="submit" class="w-full bg-primary-600 text-white py-2 rounded-lg font-medium hover:bg-primary-700 transition-colors">
          Login
        </button>
        <p id="login-error" class="text-red-600 text-sm text-center hidden">Invalid credentials</p>
      </form>
    </div>
  </div>

  <!-- Admin Dashboard -->
  <div id="admin-dashboard" class="hidden">
    <!-- Header -->
    <header class="bg-white border-b border-stone-200 sticky top-0 z-40">
      <div class="max-w-7xl mx-auto px-4 py-3 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <img src={logoIcon.src} alt="Snuggles" class="w-10 h-10" />
          <span class="text-lg font-bold text-stone-800">Admin Dashboard</span>
        </div>
        <div class="flex items-center gap-4">
          <a href="/" class="text-stone-600 hover:text-stone-800 text-sm">View Site</a>
          <button id="logout-btn" class="text-red-600 hover:text-red-700 text-sm font-medium">Logout</button>
        </div>
      </div>
    </header>

    <main class="max-w-7xl mx-auto px-4 py-8">
      <!-- Stats Cards -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
        <div class="bg-white rounded-xl p-4 border border-stone-200">
          <p class="text-sm text-stone-500">Pending Review</p>
          <p class="text-2xl font-bold text-amber-600" id="stat-pending">-</p>
        </div>
        <div class="bg-white rounded-xl p-4 border border-stone-200">
          <p class="text-sm text-stone-500">Confirmed</p>
          <p class="text-2xl font-bold text-primary-600" id="stat-confirmed">-</p>
        </div>
        <div class="bg-white rounded-xl p-4 border border-stone-200">
          <p class="text-sm text-stone-500">Completed</p>
          <p class="text-2xl font-bold text-stone-600" id="stat-completed">-</p>
        </div>
        <div class="bg-white rounded-xl p-4 border border-stone-200">
          <p class="text-sm text-stone-500">Total Revenue</p>
          <p class="text-2xl font-bold text-green-600" id="stat-revenue">-</p>
        </div>
      </div>

      <!-- Filters -->
      <div class="flex items-center gap-4 mb-6">
        <select id="status-filter" class="px-4 py-2 border border-stone-300 rounded-lg focus:ring-2 focus:ring-primary-500">
          <option value="">All Bookings</option>
          <option value="pending">Pending</option>
          <option value="pending_meetgreet">Needs Meet & Greet</option>
          <option value="confirmed">Confirmed</option>
          <option value="completed">Completed</option>
          <option value="cancelled">Cancelled</option>
        </select>
        <button id="refresh-btn" class="px-4 py-2 bg-stone-100 rounded-lg hover:bg-stone-200 transition-colors text-sm font-medium">
          Refresh
        </button>
      </div>

      <!-- Bookings Table -->
      <div class="bg-white rounded-xl border border-stone-200 overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead class="bg-stone-50 border-b border-stone-200">
              <tr>
                <th class="px-4 py-3 text-left text-xs font-medium text-stone-500 uppercase">ID</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-stone-500 uppercase">Client</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-stone-500 uppercase">Pets</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-stone-500 uppercase">Dates</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-stone-500 uppercase">Price</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-stone-500 uppercase">Status</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-stone-500 uppercase">Actions</th>
              </tr>
            </thead>
            <tbody id="bookings-table" class="divide-y divide-stone-200">
              <tr>
                <td colspan="7" class="px-4 py-8 text-center text-stone-500">Loading...</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </main>

    <!-- Booking Detail Modal -->
    <div id="booking-modal" class="fixed inset-0 bg-black/50 flex items-center justify-center z-50 hidden">
      <div class="bg-white rounded-2xl max-w-2xl w-full mx-4 max-h-[90vh] overflow-y-auto">
        <div class="p-6 border-b border-stone-200 flex items-center justify-between">
          <h2 class="text-xl font-bold text-stone-800">Booking Details</h2>
          <button id="close-modal" class="text-stone-400 hover:text-stone-600">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
        <div id="modal-content" class="p-6">
          <!-- Content loaded dynamically -->
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  .status-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 500;
  }
  .status-pending { background-color: #fef3c7; color: #92400e; }
  .status-pending_meetgreet { background-color: #fce7f3; color: #9d174d; }
  .status-confirmed { background-color: #d1fae5; color: #065f46; }
  .status-completed { background-color: #e5e7eb; color: #374151; }
  .status-cancelled { background-color: #fee2e2; color: #991b1b; }
</style>

<script define:vars={{ API_URL }}>
  let authHeader = '';
  let currentBookings = [];

  // Check for saved auth
  document.addEventListener('DOMContentLoaded', () => {
    const saved = localStorage.getItem('snuggles_admin_auth');
    if (saved) {
      authHeader = saved;
      showDashboard();
    }

    // Login form
    document.getElementById('login-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const username = document.getElementById('username').value;
      const password = document.getElementById('password').value;

      authHeader = 'Basic ' + btoa(`${username}:${password}`);

      try {
        const response = await fetch(`${API_URL}/api/admin/stats`, {
          headers: { 'Authorization': authHeader }
        });

        if (response.ok) {
          localStorage.setItem('snuggles_admin_auth', authHeader);
          showDashboard();
        } else {
          document.getElementById('login-error').classList.remove('hidden');
        }
      } catch (error) {
        document.getElementById('login-error').classList.remove('hidden');
      }
    });

    // Logout
    document.getElementById('logout-btn').addEventListener('click', () => {
      localStorage.removeItem('snuggles_admin_auth');
      authHeader = '';
      document.getElementById('admin-dashboard').classList.add('hidden');
      document.getElementById('login-modal').classList.remove('hidden');
    });

    // Filter change
    document.getElementById('status-filter').addEventListener('change', loadBookings);

    // Refresh
    document.getElementById('refresh-btn').addEventListener('click', () => {
      loadStats();
      loadBookings();
    });

    // Close modal
    document.getElementById('close-modal').addEventListener('click', closeModal);
    document.getElementById('booking-modal').addEventListener('click', (e) => {
      if (e.target === document.getElementById('booking-modal')) closeModal();
    });
  });

  function showDashboard() {
    document.getElementById('login-modal').classList.add('hidden');
    document.getElementById('admin-dashboard').classList.remove('hidden');
    loadStats();
    loadBookings();
  }

  async function loadStats() {
    try {
      const response = await fetch(`${API_URL}/api/admin/stats`, {
        headers: { 'Authorization': authHeader }
      });
      const stats = await response.json();

      document.getElementById('stat-pending').textContent = stats.pending;
      document.getElementById('stat-confirmed').textContent = stats.confirmed;
      document.getElementById('stat-completed').textContent = stats.completed;
      document.getElementById('stat-revenue').textContent = '$' + (stats.totalRevenue || 0).toLocaleString();
    } catch (error) {
      console.error('Error loading stats:', error);
    }
  }

  async function loadBookings() {
    const status = document.getElementById('status-filter').value;
    const url = status
      ? `${API_URL}/api/admin/bookings?status=${status}`
      : `${API_URL}/api/admin/bookings`;

    try {
      const response = await fetch(url, {
        headers: { 'Authorization': authHeader }
      });
      const data = await response.json();
      currentBookings = data.bookings || [];
      renderBookings();
    } catch (error) {
      console.error('Error loading bookings:', error);
    }
  }

  function renderBookings() {
    const tbody = document.getElementById('bookings-table');

    if (currentBookings.length === 0) {
      tbody.innerHTML = `
        <tr>
          <td colspan="7" class="px-4 py-8 text-center text-stone-500">No bookings found</td>
        </tr>
      `;
      return;
    }

    tbody.innerHTML = currentBookings.map(booking => {
      const pets = booking.pets || [];
      const petsStr = pets.map(p => p.name).join(', ');

      return `
        <tr class="hover:bg-stone-50">
          <td class="px-4 py-3 text-sm font-mono">${booking.id}</td>
          <td class="px-4 py-3">
            <div class="text-sm font-medium text-stone-800">${booking.client_name}</div>
            <div class="text-xs text-stone-500">${booking.client_email}</div>
          </td>
          <td class="px-4 py-3 text-sm text-stone-600">${petsStr || '-'}</td>
          <td class="px-4 py-3 text-sm text-stone-600">
            ${formatDate(booking.check_in)} - ${formatDate(booking.check_out)}
          </td>
          <td class="px-4 py-3 text-sm font-medium">
            ${booking.final_price ? '$' + booking.final_price : '$' + booking.estimated_price}
          </td>
          <td class="px-4 py-3">
            <span class="status-badge status-${booking.status}">${formatStatus(booking.status)}</span>
          </td>
          <td class="px-4 py-3">
            <button onclick="viewBooking('${booking.id}')" class="text-primary-600 hover:text-primary-700 text-sm font-medium">
              View
            </button>
          </td>
        </tr>
      `;
    }).join('');
  }

  window.viewBooking = function(id) {
    const booking = currentBookings.find(b => b.id === id);
    if (!booking) return;

    const pets = booking.pets || [];

    document.getElementById('modal-content').innerHTML = `
      <div class="space-y-6">
        <!-- Status & Actions -->
        <div class="flex items-center justify-between">
          <span class="status-badge status-${booking.status}">${formatStatus(booking.status)}</span>
          <div class="flex gap-2">
            ${booking.status === 'pending' || booking.status === 'pending_meetgreet' ? `
              <button onclick="updateBookingStatus('${booking.id}', 'confirmed')" class="px-3 py-1 bg-primary-600 text-white rounded-lg text-sm font-medium hover:bg-primary-700">
                Confirm
              </button>
              <button onclick="updateBookingStatus('${booking.id}', 'cancelled')" class="px-3 py-1 bg-red-100 text-red-700 rounded-lg text-sm font-medium hover:bg-red-200">
                Cancel
              </button>
            ` : ''}
            ${booking.status === 'confirmed' ? `
              <button onclick="updateBookingStatus('${booking.id}', 'completed')" class="px-3 py-1 bg-stone-600 text-white rounded-lg text-sm font-medium hover:bg-stone-700">
                Mark Completed
              </button>
            ` : ''}
          </div>
        </div>

        <!-- Service Details -->
        <div class="grid md:grid-cols-2 gap-4">
          <div class="bg-stone-50 rounded-lg p-4">
            <h3 class="font-medium text-stone-800 mb-2">Service</h3>
            <p class="text-stone-600">${booking.service === 'boarding' ? 'Boarding' : 'Daycare'}</p>
            <p class="text-sm text-stone-500">${formatDate(booking.check_in)} - ${formatDate(booking.check_out)}</p>
          </div>
          <div class="bg-stone-50 rounded-lg p-4">
            <h3 class="font-medium text-stone-800 mb-2">Pricing</h3>
            <p class="text-stone-600">Estimated: $${booking.estimated_price}</p>
            <div class="flex items-center gap-2 mt-1">
              <span class="text-sm text-stone-500">Final:</span>
              <input type="number" id="final-price" value="${booking.final_price || booking.estimated_price}" class="w-24 px-2 py-1 border border-stone-300 rounded text-sm" />
              <button onclick="updateFinalPrice('${booking.id}')" class="text-primary-600 hover:text-primary-700 text-sm">Save</button>
            </div>
          </div>
        </div>

        <!-- Client Info -->
        <div class="bg-stone-50 rounded-lg p-4">
          <h3 class="font-medium text-stone-800 mb-2">Client</h3>
          <p class="text-stone-800">${booking.client_name}</p>
          <p class="text-stone-600">
            <a href="mailto:${booking.client_email}" class="text-primary-600 hover:underline">${booking.client_email}</a>
          </p>
          <p class="text-stone-600">
            <a href="tel:${booking.client_phone}" class="text-primary-600 hover:underline">${booking.client_phone}</a>
          </p>
        </div>

        <!-- Pets -->
        <div>
          <h3 class="font-medium text-stone-800 mb-3">Pets</h3>
          <div class="space-y-3">
            ${pets.map(pet => `
              <div class="bg-stone-50 rounded-lg p-4">
                <div class="flex items-center justify-between">
                  <div>
                    <p class="font-medium text-stone-800">${pet.name}</p>
                    <p class="text-sm text-stone-600">${pet.type === 'dog' ? `${pet.breed}, ${pet.weight} lbs` : pet.type}</p>
                    ${pet.is_puppy ? '<span class="text-xs bg-amber-100 text-amber-700 px-2 py-0.5 rounded">Puppy</span>' : ''}
                    ${pet.needs_medication ? '<span class="text-xs bg-blue-100 text-blue-700 px-2 py-0.5 rounded ml-1">Medication</span>' : ''}
                  </div>
                  <div class="text-right">
                    <p class="text-sm text-stone-500">Suggested: ${pet.suggested_size}</p>
                    <p class="text-sm text-stone-500">Assigned: ${pet.assigned_spot_id || 'Not assigned'}</p>
                  </div>
                </div>
                ${pet.special_needs ? `<p class="text-sm text-stone-500 mt-2">Notes: ${pet.special_needs}</p>` : ''}
                ${pet.medication_notes ? `<p class="text-sm text-blue-600 mt-1">Medication: ${pet.medication_notes}</p>` : ''}
              </div>
            `).join('')}
          </div>
        </div>

        <!-- Notes -->
        <div>
          <h3 class="font-medium text-stone-800 mb-2">Internal Notes</h3>
          <textarea id="internal-notes" class="w-full px-3 py-2 border border-stone-300 rounded-lg text-sm" rows="3" placeholder="Add notes...">${booking.internal_notes || ''}</textarea>
          <button onclick="updateNotes('${booking.id}')" class="mt-2 text-sm text-primary-600 hover:text-primary-700 font-medium">Save Notes</button>
        </div>

        <!-- Metadata -->
        <div class="text-xs text-stone-400 border-t border-stone-200 pt-4">
          <p>Created: ${new Date(booking.created_at).toLocaleString()}</p>
          <p>Source: ${booking.source}</p>
          ${booking.requires_meet_greet ? '<p class="text-amber-600">Meet & Greet Required</p>' : ''}
        </div>
      </div>
    `;

    document.getElementById('booking-modal').classList.remove('hidden');
  }

  window.updateBookingStatus = async function(id, status) {
    try {
      await fetch(`${API_URL}/api/admin/bookings/${id}`, {
        method: 'PUT',
        headers: {
          'Authorization': authHeader,
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({ status })
      });
      closeModal();
      loadStats();
      loadBookings();
    } catch (error) {
      console.error('Error updating status:', error);
    }
  }

  window.updateFinalPrice = async function(id) {
    const price = parseFloat(document.getElementById('final-price').value);
    try {
      await fetch(`${API_URL}/api/admin/bookings/${id}`, {
        method: 'PUT',
        headers: {
          'Authorization': authHeader,
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({ final_price: price })
      });
      loadBookings();
    } catch (error) {
      console.error('Error updating price:', error);
    }
  }

  window.updateNotes = async function(id) {
    const notes = document.getElementById('internal-notes').value;
    try {
      await fetch(`${API_URL}/api/admin/bookings/${id}`, {
        method: 'PUT',
        headers: {
          'Authorization': authHeader,
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({ internal_notes: notes })
      });
    } catch (error) {
      console.error('Error updating notes:', error);
    }
  }

  function closeModal() {
    document.getElementById('booking-modal').classList.add('hidden');
  }

  function formatDate(dateStr) {
    if (!dateStr) return '-';
    const date = new Date(dateStr + 'T00:00:00');
    return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
  }

  function formatStatus(status) {
    const labels = {
      pending: 'Pending',
      pending_meetgreet: 'Meet & Greet',
      confirmed: 'Confirmed',
      completed: 'Completed',
      cancelled: 'Cancelled'
    };
    return labels[status] || status;
  }
</script>
